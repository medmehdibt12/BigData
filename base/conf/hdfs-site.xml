<configuration>
  <property>
    <name>dfs.webhdfs.enabled</name>
    <value>true</value>
  </property>
  <property>
    <name>dfs.namenode.safemode.min.datanodes</name>
    <value>2</value>
  </property>
  <!-- ⚠️ CORRECTION IMPORTANTE : évite le blocage en safemode -->
  <property>
    <name>dfs.namenode.safemode.threshold-pct</name>
    <value>0.99</value>
  </property>
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>/hadoop/dfs/name</value>
  </property>
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>/hadoop/dfs/data</value>
  </property>
  <!-- ⚠️ CORRECTION : évite les erreurs d'enregistrement DNS dans Docker -->
  <property>
    <name>dfs.namenode.datanode.registration.ip-hostname-check</name>
    <value>false</value>
  </property>
  <property>
    <name>dfs.replication</name>
    <value>2</value>
  </property>
</configuration>